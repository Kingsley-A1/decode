generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  name               String?
  email              String?           @unique
  emailVerified      DateTime?
  image              String?
  defaultWorkspaceId String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  accounts           Account[]
  sessions           Session[]
  defaultWorkspace   Workspace?        @relation("DefaultWorkspace", fields: [defaultWorkspaceId], references: [id], onDelete: SetNull)
  ownedWorkspaces    Workspace[]       @relation("WorkspaceOwner")
  memberships        WorkspaceMember[]
  ownedQRCodes       QRCode[]          @relation("QRCodeOwner")
  uploadedAssets     QRCodeAsset[]     @relation("AssetUploader")
  auditLogs          AuditLog[]        @relation("AuditActor")
  reviews            Review[]          @relation("ReviewAuthor")
  templateUsages     LandingPageTemplateUsage[] @relation("TemplateUsageActor")
  shortLinks         ShortLink[]       @relation("ShortLinkOwner")

  @@index([defaultWorkspaceId])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  ownerId         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  owner           User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  defaultForUsers User[]            @relation("DefaultWorkspace")
  members         WorkspaceMember[]
  qrCodes         QRCode[]
  assets          QRCodeAsset[]
  landingPages    LandingPage[]
  templateUsages  LandingPageTemplateUsage[]
  scanEvents      ScanEvent[]
  auditLogs       AuditLog[]
  shortLinks      ShortLink[]

  @@index([ownerId, deletedAt])
  @@index([deletedAt, updatedAt])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, deletedAt])
  @@index([workspaceId, role, deletedAt])
}

model QRCode {
  id             String        @id @default(cuid())
  workspaceId    String
  ownerId        String
  title          String
  type           String
  mode           String
  status         String
  slug           String?       @unique
  payload        Json
  destinationUrl String?
  designConfig   Json
  scanCount      Int           @default(0)
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner          User          @relation("QRCodeOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  assets         QRCodeAsset[]
  landingPage    LandingPage?
  scanEvents     ScanEvent[]

  @@index([workspaceId, deletedAt, updatedAt])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, mode, updatedAt])
  @@index([ownerId, updatedAt])
}

model QRCodeAsset {
  id            String       @id @default(cuid())
  workspaceId   String
  qrCodeId      String?
  landingPageId String?
  uploaderId    String?
  purpose       String
  status        String
  bucket        String
  key           String       @unique
  publicUrl     String?
  contentType   String
  fileSizeBytes Int
  checksum      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  qrCode        QRCode?      @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  landingPage   LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  uploader      User?        @relation("AssetUploader", fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([workspaceId, deletedAt, updatedAt])
  @@index([qrCodeId, purpose])
  @@index([landingPageId, purpose])
  @@index([uploaderId, createdAt])
}

model LandingPage {
  id          String        @id @default(cuid())
  workspaceId String
  qrCodeId    String?       @unique
  templateId  String?
  type        String
  title       String
  status      String
  content     Json
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  qrCode      QRCode?       @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  template    LandingPageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  assets      QRCodeAsset[]
  templateUsages LandingPageTemplateUsage[]

  @@index([workspaceId, deletedAt, updatedAt])
  @@index([workspaceId, status, updatedAt])
  @@index([templateId])
}

model ScanEvent {
  id              String    @id @default(cuid())
  workspaceId     String
  qrCodeId        String
  scannedAt       DateTime  @default(now())
  deviceClass     String?
  browser         String?
  operatingSystem String?
  referrer        String?
  country         String?
  region          String?
  ipHash          String?
  userAgentHash   String?
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  qrCode          QRCode    @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  @@index([workspaceId, scannedAt])
  @@index([qrCodeId, scannedAt])
  @@index([workspaceId, deviceClass, scannedAt])
}

model LinkCheck {
  id              String    @id @default(cuid())
  normalizedUrl   String    @unique
  verdict         String
  confidence      Int
  reasons         Json
  evidence        Json?
  probeSummary    Json?
  threatIntelTtl  DateTime?
  checkedAt       DateTime  @default(now())
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([expiresAt])
  @@index([verdict, checkedAt])
  @@index([normalizedUrl, expiresAt])
}

model ShortLink {
  id              String          @id @default(cuid())
  workspaceId     String?
  ownerId         String?
  slug            String          @unique
  destinationUrl  String
  normalizedUrl   String
  status          String          @default("active")
  verdictAtCreate String
  lastVerdict     String?
  lastVerifiedAt  DateTime?
  scanCount       Int             @default(0)
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  workspace       Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  owner           User?           @relation("ShortLinkOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  scans           ShortLinkScan[]

  @@index([workspaceId, deletedAt, updatedAt])
  @@index([ownerId, updatedAt])
  @@index([status, expiresAt])
  @@index([normalizedUrl])
}

model ShortLinkScan {
  id              String    @id @default(cuid())
  shortLinkId     String
  scannedAt       DateTime  @default(now())
  deviceClass     String?
  browser         String?
  operatingSystem String?
  referrer        String?
  country         String?
  region          String?
  ipHash          String?
  userAgentHash   String?
  shortLink       ShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([shortLinkId, scannedAt])
  @@index([scannedAt])
}

model Review {
  id           String    @id @default(cuid())
  userId       String?
  name         String
  email        String?
  rating       Int
  title        String
  body         String
  status       String    @default("published")
  helpfulCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  author       User?     @relation("ReviewAuthor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, deletedAt, createdAt])
  @@index([userId, createdAt])
  @@index([deletedAt])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor       User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
}

model AdminUser {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String
  role              String
  status            String             @default("active")
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  disabledAt        DateTime?
  sessions          AdminSession[]
  authEvents        AdminAuthEvent[]
  platformAuditLogs PlatformAuditLog[] @relation("PlatformAuditActor")
  createdLandingPageTemplates LandingPageTemplate[] @relation("TemplateCreator")
  updatedLandingPageTemplates LandingPageTemplate[] @relation("TemplateUpdater")
  uploadedLandingPageTemplateAssets LandingPageTemplateUploadedAsset[] @relation("TemplateAssetUploader")

  @@index([role, status])
  @@index([status, createdAt])
}

model LandingPageTemplate {
  id                   String                     @id @default(cuid())
  key                  String                     @unique
  type                 String
  label                String
  description          String
  category             String
  industry             String
  status               String                     @default("draft")
  source               String                     @default("admin")
  sortPriority         Int                        @default(1000)
  flags                Json
  tags                 Json
  recommendedFor       String
  requiredFields       Json
  optionalFields       Json
  defaultTitle         String
  defaultContent       Json
  thumbnail            Json
  mobilePreview        Json
  accessibilityNotes   String
  usageCount           Int                        @default(0)
  lastUsedAt           DateTime?
  publishedAt          DateTime?
  archivedAt           DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  deletedAt            DateTime?
  createdByAdminUserId String?
  updatedByAdminUserId String?
  createdBy            AdminUser?                 @relation("TemplateCreator", fields: [createdByAdminUserId], references: [id], onDelete: SetNull)
  updatedBy            AdminUser?                 @relation("TemplateUpdater", fields: [updatedByAdminUserId], references: [id], onDelete: SetNull)
  assets               LandingPageTemplateAsset[]
  landingPages         LandingPage[]
  usages               LandingPageTemplateUsage[]

  @@index([status, sortPriority, updatedAt])
  @@index([category, status])
  @@index([type, status])
  @@index([source, status])
  @@index([deletedAt, updatedAt])
  @@index([createdByAdminUserId, createdAt])
  @@index([updatedByAdminUserId, updatedAt])
}

model LandingPageTemplateAsset {
  id         String              @id @default(cuid())
  templateId String
  uploadedAssetId String?
  slot       String
  label      String
  kind       String
  required   Boolean             @default(false)
  assetPath  String?
  alt        String?
  width      Int?
  height     Int?
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  template   LandingPageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  uploadedAsset LandingPageTemplateUploadedAsset? @relation(fields: [uploadedAssetId], references: [id], onDelete: SetNull)

  @@unique([templateId, slot])
  @@index([templateId, sortOrder])
  @@index([uploadedAssetId])
  @@index([kind, required])
}

model LandingPageTemplateUploadedAsset {
  id                  String                     @id @default(cuid())
  uploaderAdminUserId String?
  bucket              String
  key                 String                     @unique
  publicUrl           String?
  contentType         String
  fileSizeBytes       Int
  checksum            String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?
  uploaderAdminUser   AdminUser?                 @relation("TemplateAssetUploader", fields: [uploaderAdminUserId], references: [id], onDelete: SetNull)
  templateAssets      LandingPageTemplateAsset[]

  @@index([uploaderAdminUserId, createdAt])
  @@index([deletedAt, createdAt])
}

model LandingPageTemplateUsage {
  id            String               @id @default(cuid())
  templateId    String
  workspaceId   String?
  landingPageId String?
  actorUserId   String?
  context       String               @default("landing_page_create")
  usedAt        DateTime             @default(now())
  createdAt     DateTime             @default(now())
  template      LandingPageTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  workspace     Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  landingPage   LandingPage?         @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  actor         User?                @relation("TemplateUsageActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([templateId, usedAt])
  @@index([workspaceId, usedAt])
  @@index([landingPageId, usedAt])
  @@index([actorUserId, usedAt])
}

model AdminSession {
  id               String    @id @default(cuid())
  adminUserId      String
  sessionTokenHash String    @unique
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  revokedAt        DateTime?
  ipHash           String?
  userAgentHash    String?
  adminUser        AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, revokedAt, expiresAt])
  @@index([expiresAt])
}

model AdminAuthEvent {
  id            String     @id @default(cuid())
  adminUserId   String?
  email         String
  event         String
  outcome       String
  reason        String?
  requestId     String
  ipHash        String?
  userAgentHash String?
  createdAt     DateTime   @default(now())
  adminUser     AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([adminUserId, createdAt])
  @@index([event, outcome, createdAt])
  @@index([requestId])
}

model PlatformAuditLog {
  id               String     @id @default(cuid())
  actorAdminUserId String?
  action           String
  entityType       String
  entityId         String?
  requestId        String?
  metadata         Json?
  ipHash           String?
  userAgentHash    String?
  createdAt        DateTime   @default(now())
  actor            AdminUser? @relation("PlatformAuditActor", fields: [actorAdminUserId], references: [id], onDelete: SetNull)

  @@index([actorAdminUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@index([requestId])
  @@index([createdAt])
}
