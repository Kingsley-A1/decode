# App
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js / NextAuth
# Use the same high-entropy value for AUTH_SECRET and NEXTAUTH_SECRET while
# Decode is on NextAuth v4 compatibility. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-secret"
NEXTAUTH_SECRET="replace-with-the-same-strong-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# GitHub OAuth
GITHUB_ID="replace-with-github-oauth-client-id"
GITHUB_SECRET="replace-with-github-oauth-client-secret"

# Admin credentials
# Generate with: node scripts/hash-admin-secret.mjs 123456
ADMIN_REGISTRATION_CODE_HASH="replace-with-scrypt-hash"
ADMIN_SESSION_TTL_SECONDS="28800"
ADMIN_AUTH_RATE_LIMIT_WINDOW_SECONDS="900"
ADMIN_AUTH_MAX_ATTEMPTS="8"

# CockroachDB / Prisma
DATABASE_URL="postgresql://user:password@host:26257/defaultdb?sslmode=verify-full"

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID="replace-with-cloudflare-account-id"
R2_ACCESS_KEY_ID="replace-with-r2-access-key-id"
R2_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"
R2_BUCKET_NAME="decode-assets"
R2_ENDPOINT="https://replace-with-account-id.r2.cloudflarestorage.com"
R2_PUBLIC_BASE_URL="https://assets.example.com"

# Observability
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
SENTRY_RELEASE=""
VERCEL_ENV="development"
NEXT_PUBLIC_VERCEL_ENV="development"

# Release checks
PLAYWRIGHT_BASE_URL="http://localhost:3000"
LHCI_GITHUB_APP_TOKEN=""
